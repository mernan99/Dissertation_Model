# libvorbisfile pkg-config source file

prefix=U:/envs/assimulo_env/Library
exec_prefix=U:/envs/assimulo_env/Library/bin
libdir=U:/envs/assimulo_env/Library/lib
includedir=U:/envs/assimulo_env/Library/include

Name: vorbisfile
Description: vorbisfile is a library that provides a convenient high-level API for decoding and basic manipulation of all Vorbis I audio streams
Version: 1.3.7
Requires.private: vorbis
Conflicts:
Libs: -L${libdir} -lvorbisfile
Cflags: -I${includedir}
