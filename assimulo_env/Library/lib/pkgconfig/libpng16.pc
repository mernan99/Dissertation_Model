prefix=U:/envs/assimulo_env/Library
exec_prefix=U:/envs/assimulo_env/Library
libdir=U:/envs/assimulo_env/Library/lib
includedir=U:/envs/assimulo_env/Library/include/libpng16

Name: libpng
Description: Loads and saves PNG files
Version: 1.6.44
Requires.private: zlib
Libs: -L${libdir} -lpng16
Libs.private: -lz
Cflags: -I${includedir}
